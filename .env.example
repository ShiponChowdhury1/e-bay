# MongoDB (Required)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ebay-marketplace?retryWrites=true&w=majority

# JWT Secrets (Required - use strong random strings)
JWT_ACCESS_SECRET=your_access_token_secret_key_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here_min_32_chars

# Email/SMTP Configuration (Required for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Public Variables (NEXT_PUBLIC_ prefix for client-side access)
NEXT_PUBLIC_API_URL=https://your-backend-api.com/api/v1
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Stripe (if using payment features)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
